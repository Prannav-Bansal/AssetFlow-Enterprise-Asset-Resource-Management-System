# Base URL of the AssetFlow backend API (must include the /api suffix).
#
# IMPORTANT: NEXT_PUBLIC_* variables are inlined at BUILD time, so this must be
# set in Render's environment BEFORE the build runs — changing it later requires
# a rebuild/redeploy.
#
# Local dev:  http://localhost:5000/api
# Production: https://<your-backend>.onrender.com/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api
