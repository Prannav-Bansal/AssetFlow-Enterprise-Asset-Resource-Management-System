# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Allowed frontend origin(s) for CORS. Comma-separate multiple values, e.g.
# CLIENT_URL=http://localhost:3000,https://your-frontend.onrender.com
CLIENT_URL=http://localhost:3000

# ── Database ────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/assetflow

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Cloudinary (optional) ───────────────────────────────
# If these are left blank, uploads fall back to local disk storage (/uploads).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Cron ────────────────────────────────────────────────
# Set to "true" to disable background jobs (e.g. in tests).
DISABLE_CRON=false
